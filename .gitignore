# =============================================================
#  Lansub MES — .gitignore
#  Keeps secrets, build artifacts, and OS junk out of Git
# =============================================================


# ── SECRETS & ENVIRONMENT ─────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.crt
secrets/


# ── PYTHON ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
ENV/
.env/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json

# Type checking
.pytype/


# ── NODE / FRONTEND ───────────────────────────────────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm

# Build output
dist/
frontend/dist/
build/
*.local

# Vite cache
.vite/
frontend/.vite/


# ── DOCKER ────────────────────────────────────────────────────
# Docker volumes & data (if mounted locally)
mongo-data/
mosquitto/data/
mosquitto/log/


# ── OS FILES ──────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── IDEs & EDITORS ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace


# ── LOGS ──────────────────────────────────────────────────────
logs/
*.log
*.log.*


# ── MISC ──────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
