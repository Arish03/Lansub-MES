# =============================================================
#  Lansub MES — Environment Variables Template
#
#  📋 SETUP INSTRUCTIONS:
#  1. Copy this file:  cp .env.example .env
#  2. Fill in every value below with your real credentials
#  3. NEVER commit the .env file to Git
# =============================================================

# ── VM Public IP ──────────────────────────────────────────────
# Run: curl ifconfig.me   on your server to find this
VM_PUBLIC_IP=YOUR_VM_PUBLIC_IP

# ── MongoDB ───────────────────────────────────────────────────
MONGO_USER=lansub
MONGO_PASS=CHANGE_THIS_STRONG_PASSWORD
MONGO_DB=lansub_mes

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET

# ── MQTT Broker ───────────────────────────────────────────────
MQTT_USER=lansub_mqtt
MQTT_PASS=CHANGE_THIS_STRONG_PASSWORD

# ── Ollama (Local AI — Optional) ────────────────────────────
# Runs AI report generation locally via Ollama — no API key needed!
# Install Ollama: https://ollama.com  then: ollama pull qwen2.5:7b
# Leave OLLAMA_MODEL blank to use template-based reports instead
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
